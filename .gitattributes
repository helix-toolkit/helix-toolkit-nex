# Auto-detect text files and normalize line endings
# Git stores LF in the repo and, by default, checks out native line endings (CRLF on Windows, LF on Linux/Mac); some file types below explicitly override this behavior.
* text=auto

# Source code - always normalize to LF in repo
*.cs text eol=crlf diff=csharp
*.csx text eol=crlf diff=csharp
*.xaml text
*.xml text
*.json text
*.yml text
*.yaml text
*.md text
*.txt text

# Project/solution files
*.sln text eol=crlf
*.slnx text eol=crlf
*.csproj text
*.props text
*.targets text
*.nuspec text
*.config text
*.ruleset text

# Shell scripts - always LF (even on Windows checkout)
*.sh text eol=lf

# PowerShell scripts - keep executable .ps1 files LF for cross-platform shebang support
*.ps1 text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf

# Batch scripts - always CRLF
*.cmd text eol=crlf
*.bat text eol=crlf

# Git config files
.gitattributes text
.gitignore text
.editorconfig text

# Binary files - never touch these
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.tif binary
*.tiff binary
*.dds binary
*.raw binary
*.dat binary
*.bin binary
*.dll binary
*.exe binary
*.pdb binary
*.nupkg binary
