<?xml version="1.0" encoding="utf-8"?>
<Window
  x:Class="WinUIInterop.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:WinUIInterop"
  xmlns:common="using:Interop.Common"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:toolkits="using:CommunityToolkit.WinUI.Controls"
  xmlns:hx="using:HelixToolkit.Nex.WinUI"
  mc:Ignorable="d"
  Title="HelixToolkit.Nex - WinUI Interop (Minecraft)"
>
  <Window.SystemBackdrop>
    <MicaBackdrop />
  </Window.SystemBackdrop>

  <Grid>
    <Grid.DataContext>
      <common:MainViewModel />
    </Grid.DataContext>
    <Grid.ColumnDefinitions>
      <ColumnDefinition></ColumnDefinition>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition></ColumnDefinition>
    </Grid.ColumnDefinitions>
    <hx:HelixViewport x:Name="ViewportFly" Grid.Column="0" Engine="{Binding Engine}" ViewportClient="{Binding FlyClient}" />
    <toolkits:GridSplitter
      Grid.Column="1"
      ResizeBehavior="PreviousAndNext"
      ResizeDirection="Columns"
    />
    <hx:HelixViewport x:Name="ViewportOverhead" Grid.Column="2" Engine="{Binding Engine}" ViewportClient="{Binding OverheadClient}" />
    <Grid
      Grid.ColumnSpan="3"
      VerticalAlignment="Bottom"
      HorizontalAlignment="Center"
      Margin="10"
      Background="MidnightBlue"
    >
      <StackPanel Orientation="Horizontal">
        <Button Margin="10" MinWidth="120" Content="WinUI Button 1" />
        <Button Margin="10" MinWidth="120" Content="WinUI Button 2" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
